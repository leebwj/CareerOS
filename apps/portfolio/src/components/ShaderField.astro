---
// Blueprint Field — a hand-written WebGL fragment shader (no libraries).
// THREE switchable modes — Field (topographic contours), Flow (plasma bands),
// Dots (pulsing dot-matrix) — that crossfade into each other. Reuses one program
// (uModeA/uModeB/uMix blend). Lazy, paused offscreen, DPR-capped, static frame
// under reduced-motion. variant="bleed" → full-bleed page surface (cursor reacts
// across the whole hero); variant="band" → wide short strip.
const { variant, mode = 0 } = Astro.props;
---

<div class:list={["vp", variant === "band" && "vp--band", variant === "bleed" && "vp--bleed"]} data-mode={mode} data-cursor="Poke">
  <canvas class="vp-canvas"></canvas>
  <div class="vp-hud" aria-hidden="true">
    <span class="vp-tick tl"></span><span class="vp-tick tr"></span>
    <span class="vp-tick bl"></span><span class="vp-tick br"></span>
    <span class="vp-label vp-tl">field.glsl</span>
    <span class="vp-label vp-tr"><i class="vp-dot"></i> live</span>
    <span class="vp-label vp-br">hover to disturb&nbsp;↜</span>
  </div>
</div>

<style>
  .vp {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-card);
    box-shadow: 0 1px 2px color-mix(in oklab, var(--color-cobalt-deep) 12%, transparent);
  }
  @media (min-width: 880px) { .vp { aspect-ratio: 1 / 1; } }
  /* horizon-band variant: wide + short */
  .vp--band { aspect-ratio: auto; height: clamp(120px, 17vh, 180px); }
  @media (min-width: 880px) { .vp--band { aspect-ratio: auto; height: clamp(130px, 15vh, 190px); } }
  /* full-bleed variant: fills the hero behind the content */
  .vp--bleed { position: absolute; inset: 0; width: 100%; height: 100%; aspect-ratio: auto; border: 0; border-radius: 0; box-shadow: none; background: transparent; z-index: 0; }
  .vp--bleed .vp-hud { display: none; }
  .vp--bleed::before { opacity: .22; }

  .vp-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  /* CSS blueprint grid is the no-WebGL / pre-paint fallback */
  .vp::before {
    content: "";
    position: absolute; inset: 0; z-index: 0;
    background:
      linear-gradient(var(--color-line) 1px, transparent 1px) 0 0 / 24px 24px,
      linear-gradient(90deg, var(--color-line) 1px, transparent 1px) 0 0 / 24px 24px;
    opacity: .6;
  }
  .vp-canvas { z-index: 1; }
  .vp-hud { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
  .vp-tick { position: absolute; width: 9px; height: 9px; border: 1.5px solid var(--color-cobalt); }
  .vp-tick.tl { top: 11px; left: 11px; border-right: 0; border-bottom: 0; }
  .vp-tick.tr { top: 11px; right: 11px; border-left: 0; border-bottom: 0; }
  .vp-tick.bl { bottom: 11px; left: 11px; border-right: 0; border-top: 0; }
  .vp-tick.br { bottom: 11px; right: 11px; border-left: 0; border-top: 0; }
  .vp-label { position: absolute; font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--color-cobalt-deep); }
  .vp-tl { top: 15px; left: 28px; }
  .vp-tr { top: 15px; right: 28px; display: flex; align-items: center; gap: 5px; }
  .vp-br { bottom: 15px; right: 28px; }
  .vp-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-cobalt); display: inline-block; animation: vpblink 1.8s steps(1) infinite; }
  @keyframes vpblink { 50% { opacity: .2; } }
  @media (prefers-reduced-motion: reduce) { .vp-dot { animation: none; } }
</style>

<script>
  // Defer the WebGL setup (context + shader compile + link) off the critical
  // path: yield one idle tick (capped at 300ms) so first paint + interactivity
  // land first. The canvas fades in anyway, so the deferral is imperceptible.
  await new Promise<void>((resolve) => {
    const ric = (window as any).requestIdleCallback as ((cb: () => void, o?: { timeout: number }) => void) | undefined;
    ric ? ric(() => resolve(), { timeout: 300 }) : setTimeout(resolve, 1);
  });

  const canvas = document.querySelector(".vp-canvas") as HTMLCanvasElement | null;
  const wrap = canvas?.closest(".vp") as HTMLElement | null;
  if (canvas && wrap) {
    const gl = canvas.getContext("webgl", { antialias: true, alpha: false, premultipliedAlpha: false });
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = matchMedia("(hover: hover) and (pointer: fine)").matches;
    const bleed = wrap.classList.contains("vp--bleed");

    if (gl) {
      const deriv = gl.getExtension("OES_standard_derivatives");
      const W = deriv ? "fwidth(v)" : "0.03";
      const GW = deriv ? "fwidth(uv.x) * 22.0" : "0.04";

      const vsrc = `
        attribute vec2 p; varying vec2 vUv;
        void main(){ vUv = p * 0.5 + 0.5; gl_Position = vec4(p, 0.0, 1.0); }`;

      const fsrc =
        (deriv ? "#extension GL_OES_standard_derivatives : enable\n" : "") +
        `precision highp float;
        varying vec2 vUv;
        uniform vec2  uRes;
        uniform float uTime;
        uniform vec2  uMouse;   // 0..1
        uniform vec3  uBg;
        uniform vec3  uLine;
        uniform vec3  uDeep;
        uniform int   uModeA;
        uniform int   uModeB;
        uniform float uMix;
        uniform sampler2D uWater;  // live heightfield: REAL propagating waves (ping-pong sim)
        uniform vec2  uWTexel;     // 1 / sim resolution

        float hash(vec2 p){ p = fract(p * vec2(123.34, 345.45)); p += dot(p, p + 34.345); return fract(p.x * p.y); }
        float noise(vec2 p){
          vec2 i = floor(p), f = fract(p);
          float a = hash(i), b = hash(i + vec2(1.0, 0.0)), c = hash(i + vec2(0.0, 1.0)), d = hash(i + vec2(1.0, 1.0));
          vec2 u = f * f * (3.0 - 2.0 * f);
          return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
        }
        float fbm(vec2 p){
          float s = 0.0, a = 0.5; mat2 m = mat2(1.6, 1.2, -1.2, 1.6);
          for(int i = 0; i < 5; i++){ s += a * noise(p); p = m * p; a *= 0.5; }
          return s;
        }

        // mode 0 — topographic contour lines + faint CAD grid
        vec3 fxContour(vec2 p, vec2 uv, float ar, float ripple){
          float t = uTime * 0.05;
          vec2 q = vec2(fbm(p + vec2(0.0, t)), fbm(p + vec2(5.2, -t)));
          float field = fbm(p + 1.7 * q + ripple * 0.9) + ripple * 0.22;
          float v = field * 7.0;
          float w = ${W};
          float d = abs(fract(v) - 0.5);
          float line = 1.0 - smoothstep(0.0, max(w * 1.4, 0.001), d);
          vec2 g = abs(fract(uv * vec2(22.0 * ar, 22.0)) - 0.5);
          float grid = 1.0 - smoothstep(0.0, max(${GW}, 0.001), min(g.x, g.y));
          vec3 col = uBg;
          col = mix(col, uDeep, grid * 0.10);
          col = mix(col, uLine, line * 0.85);
          col = mix(col, uLine, ripple * 0.16);
          return col;
        }
        // mode 1 — flowing plasma bands (domain-warped)
        vec3 fxFlow(vec2 p, vec2 uv, float ripple){
          float t = uTime * 0.04;
          vec2 q = vec2(fbm(p * 0.8 + vec2(0.0, t)), fbm(p * 0.8 + vec2(3.1, -t)));
          float f = fbm(p * 0.9 + 2.0 * q + ripple * 1.2);
          float bands = 0.5 + 0.5 * sin(f * 9.0 + uTime * 0.25);
          float glow = smoothstep(0.32, 0.95, bands);
          vec3 col = mix(uBg, mix(uDeep, uLine, 0.65), glow * 0.5);
          col = mix(col, uLine, ripple * 0.25);
          return col;
        }
        // mode 2 — pulsing dot matrix (field drives dot radius)
        vec3 fxDots(vec2 p, vec2 uv, float ar, float ripple){
          float field = fbm(p * 0.7 + uTime * 0.05) + ripple * 0.9;
          vec2 cell = fract(uv * vec2(30.0 * ar, 30.0)) - 0.5;
          float d = length(cell);
          float r = 0.10 + 0.36 * clamp(field, 0.0, 1.2);
          float dot = 1.0 - smoothstep(r - 0.05, r, d);
          return mix(uBg, uLine, dot * 0.9);
        }

        // ── mode 3 — WATER / liquid glass, rebuilt on the canon ─────────────
        // References: Evan Wallace's webgl-water (fresnel + refraction +
        // caustics), TDM's Seascape (layered directional waves), Dave Hoskins'
        // "Tileable Water Caustic" (Shadertoy MdlXz8 — the caustic loop below
        // is an adaptation), and Apple Liquid-Glass teardowns (frosted blur,
        // EDGE-ONLY chromatic aberration, edge highlight).
        float wGridF(vec2 uv, float ar, float gw){
          vec2 gc = abs(fract(uv * vec2(22.0 * ar, 22.0)) - 0.5);
          return 1.0 - smoothstep(0.0, gw, min(gc.x, gc.y));
        }
        // caustic light web — adapted from Dave Hoskins, Shadertoy MdlXz8.
        // NOTE the magnitude convention: mod(...) - 250.0 keeps |cp| ~ 250 so
        // cp * inten ~ 1.25 inside the pole divisions; without it the 1/length
        // terms explode to INF and the whole frame saturates to a constant.
        float wCaustic(vec2 p){
          vec2 cp = mod(p * 2.0, 6.28318) - 250.0;
          vec2 ci = cp;
          float c = 1.0;
          float inten = 0.005;
          for (int k = 0; k < 4; k++){
            float t = uTime * 0.4 * (1.0 - (3.5 / float(k + 1)));
            ci = cp + vec2(cos(t - ci.x) + sin(t + ci.y), sin(t - ci.y) + cos(t + ci.x));
            c += 1.0 / length(vec2(cp.x / (sin(ci.x + t) / inten), cp.y / (cos(ci.y + t) / inten)));
          }
          c /= 4.0;
          c = 1.17 - pow(c, 1.4);
          return pow(abs(c), 6.0);
        }
        vec3 fxWater(vec2 p, vec2 uv, float ar, float ripple, vec2 m){
          float t = uTime;
          // ── ambient: ONE smooth slow warped swell. Coherent large-scale
          // curvature (the Prismal / liquid-glass lesson) — no noisy chop. ──
          vec2 q = vec2(fbm(p * 0.5 + vec2(0.0, t * 0.06)), fbm(p * 0.5 + vec2(4.7, -t * 0.05)));
          float swell = fbm(p * 0.8 + 1.4 * q) - 0.5;
          // ── interaction: a REAL propagating heightfield (Hugo Elias wave
          // kernel on a ping-pong buffer — the jquery.ripples / webgl-water
          // technique). The cursor plows a continuous wake; waves travel,
          // interfere, and decay physically. h in R channel, 0.5 = rest. ──
          float hc = texture2D(uWater, uv).r - 0.5;
          float hl = texture2D(uWater, uv - vec2(uWTexel.x * 1.5, 0.0)).r;
          float hr = texture2D(uWater, uv + vec2(uWTexel.x * 1.5, 0.0)).r;
          float hb = texture2D(uWater, uv - vec2(0.0, uWTexel.y * 1.5)).r;
          float ht = texture2D(uWater, uv + vec2(0.0, uWTexel.y * 1.5)).r;
          vec2 grad = vec2(hr - hl, ht - hb) * 30.0          // wave normals: strong + coherent
                    + (q - 0.5) * 0.55;                      // gentle ambient wobble
          float h = hc * 1.7 + swell * 0.35;
          // ── shading terms ──
          vec3 n = normalize(vec3(-grad.x * 0.42, -grad.y * 0.42, 1.0));
          // (ripple gaussian intentionally unused here — the cursor acts on the
          // water ONLY through the physical drop impulses above)
          float fres = pow(clamp(1.0 - n.z, 0.0, 1.0), 1.3) * 3.5;   // grazing slopes reflect
          fres = clamp(fres, 0.0, 1.0);
          float edgeAmt = clamp(length(grad) * 0.55, 0.0, 1.0);      // where light bends most
          // ── the blueprint, refracted + frosted (multi-tap) + edge fringe ──
          float gw = max(${GW}, 0.001);
          vec2 ruv = uv + n.xy * 0.034;
          float g0 = wGridF(ruv, ar, gw);
          float gB = (g0                                              // frosted soften: ~1px taps
            + wGridF(ruv + vec2(0.0012, 0.0007), ar, gw)
            + wGridF(ruv + vec2(-0.0007, 0.0012), ar, gw)
            + wGridF(ruv + vec2(-0.0012, -0.0007), ar, gw)) * 0.25;
          float split = 0.011 * edgeAmt;                              // EDGE-ONLY aberration
          vec3 grid3 = vec3(
            wGridF(ruv - n.xy * split, ar, gw),
            g0,
            wGridF(ruv + n.xy * split, ar, gw));
          // sharp fringed lines where light bends; slightly soft where calm
          vec3 gridCol = mix(grid3, vec3(gB), 0.45 * (1.0 - edgeAmt));
          // ── compose: depth body → drawing → caustics → frost → fresnel →
          //    edge highlight → sun glint ──
          vec3 milky = mix(uLine, vec3(1.0), 0.65);
          vec3 col = mix(uBg, uDeep, 0.34);
          col = mix(col, mix(uDeep, uLine, 0.68), gridCol * 0.92);
          float caust = wCaustic(p + q * 0.4);
          col += mix(uLine, vec3(1.0), 0.35) * caust *
            (0.40 + 0.35 * clamp(swell * 2.0 + 0.5, 0.0, 1.0) + 0.7 * clamp(hc * 4.0, 0.0, 1.0));
          col = mix(col, milky, 0.05 + 0.05 * (1.0 - edgeAmt));       // calm glass diffuses milkier
          col = mix(col, mix(milky, uLine, 0.45), fres * 0.42);       // sky sheen on slopes
          col += uLine * pow(edgeAmt, 3.0) * 0.25;                    // liquid-glass edge highlight
          float spec = pow(max(dot(n, normalize(vec3(0.25, 0.35, 0.92))), 0.0), 90.0);
          col += vec3(spec * 0.8);                                    // overhead sun → real glints
          return col;
        }

        // ── mode 4 — the terminal underneath (v1, Brian's pick): the field
        // quantized into character cells, each speaking its intensity through a
        // 6-step glyph ramp (space . : + checker block) bit-packed into floats
        // and decoded with mod/exp2 (GLSL ES 1.0 has no bitwise ops). Hard
        // pixel edges on purpose; 5% scanlines; one cursor cell blinking 500ms.
        float glyphBit(float n, vec2 sub){
          float idx = sub.y * 3.0 + sub.x;                    // 3x5 lattice, 15 bits
          return mod(floor(n / exp2(idx)), 2.0);
        }
        // v1 ramp (Brian's pick): space . : + checker block on a 3x5 lattice
        float glyphFor(float v){
          if (v < 0.18) return 0.0;                           // space
          else if (v < 0.34) return 128.0;                    // . (center px)
          else if (v < 0.50) return 1040.0;                   // :
          else if (v < 0.66) return 1488.0;                   // +
          else if (v < 0.82) return 21845.0;                  // checker (dense)
          return 32767.0;                                     // full block
        }
        vec3 fxAscii(vec2 uv, float ar, vec2 m){
          vec2 grid = vec2(floor(30.0 * ar * 1.66), 30.0);    // cell aspect ~3:5
          vec2 cellUV = uv * grid;
          vec2 id = floor(cellUV);
          vec2 sub = floor(fract(cellUV) * vec2(3.0, 5.0));
          vec2 cUV = (id + 0.5) / grid;                       // field sampled at cell center
          vec2 cP = vec2(cUV.x * ar, cUV.y) * 3.0;
          float v = fbm(cP * 0.85 + uTime * 0.055);
          float dm = distance(cP, m);
          v = clamp(v * 0.9 + exp(-dm * dm * 0.6) * 0.65, 0.0, 1.0);
          float bit = glyphBit(glyphFor(v), sub);
          vec3 col = mix(uBg, mix(uDeep, uLine, 0.35 + 0.65 * v), bit);
          col *= 0.95 + 0.05 * mod(id.y, 2.0);                // scanlines @5%
          vec2 cursor = floor(vec2(0.82, 0.13) * grid);       // blinking cursor, 500ms
          if (id.x == cursor.x && id.y == cursor.y && mod(uTime, 1.0) < 0.5) col = mix(col, uLine, 0.9);
          return col;
        }

        vec3 pick(int mode, vec2 p, vec2 uv, float ar, float ripple, vec2 m){
          if(mode == 1) return fxFlow(p, uv, ripple);
          else if(mode == 2) return fxDots(p, uv, ar, ripple);
          else if(mode == 3) return fxWater(p, uv, ar, ripple, m);
          else if(mode == 4) return fxAscii(uv, ar, m);
          return fxContour(p, uv, ar, ripple);
        }

        void main(){
          vec2 uv = vUv;
          float ar = uRes.x / max(uRes.y, 1.0);
          vec2 p = vec2(uv.x * ar, uv.y) * 3.0;
          vec2 m = vec2(uMouse.x * ar, uMouse.y) * 3.0;
          float md = distance(p, m);
          float ripple = exp(-md * md * 0.6);

          // perf: at rest (no crossfade, 99% of the time) evaluate the field
          // ONCE. uMix is a uniform → the branch is fully coherent, zero
          // divergence, identical output — ~2x fill headroom in every mode.
          vec3 col;
          if (uMix < 0.002) {
            col = pick(uModeA, p, uv, ar, ripple, m);
          } else {
            vec3 cA = pick(uModeA, p, uv, ar, ripple, m);
            vec3 cB = pick(uModeB, p, uv, ar, ripple, m);
            col = mix(cA, cB, clamp(uMix, 0.0, 1.0));
          }

          float vig = smoothstep(1.25, 0.25, distance(uv, vec2(0.5)));
          col = mix(uBg, col, 0.4 + 0.6 * vig);
          gl_FragColor = vec4(col, 1.0);
        }`;

      const compile = (type: number, src: string) => {
        const sh = gl.createShader(type)!;
        gl.shaderSource(sh, src); gl.compileShader(sh);
        return gl.getShaderParameter(sh, gl.COMPILE_STATUS) ? sh : null;
      };
      const vs = compile(gl.VERTEX_SHADER, vsrc);
      const fs = compile(gl.FRAGMENT_SHADER, fsrc);

      if (vs && fs) {
        const prog = gl.createProgram()!;
        gl.attachShader(prog, vs); gl.attachShader(prog, fs); gl.linkProgram(prog);
        gl.useProgram(prog);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
        const loc = gl.getAttribLocation(prog, "p");
        gl.enableVertexAttribArray(loc);
        gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

        const U = (n: string) => gl.getUniformLocation(prog, n);
        const uRes = U("uRes"), uTime = U("uTime"), uMouse = U("uMouse");
        const uBg = U("uBg"), uLine = U("uLine"), uDeep = U("uDeep");
        const uModeA = U("uModeA"), uModeB = U("uModeB"), uMix = U("uMix");
        const uWater = U("uWater"), uWTexel = U("uWTexel");

        // ── interactive water heightfield: a REAL wave simulation (Hugo Elias
        // kernel on ping-pong buffers — the jquery.ripples / webgl-water
        // technique). Three small RGBA8 targets rotate (cur → prev → out);
        // R stores height, 0.5 = rest. Stepped only while Water is on screen. ──
        const simFsrc = `precision highp float;
          varying vec2 vUv;
          uniform sampler2D uCur;
          uniform sampler2D uPrev;
          uniform vec2 uTexel;
          uniform vec2 uSplat;
          uniform float uSplatAmp;
          void main(){
            float l = texture2D(uCur, vUv - vec2(uTexel.x, 0.0)).r - 0.5;
            float r = texture2D(uCur, vUv + vec2(uTexel.x, 0.0)).r - 0.5;
            float b = texture2D(uCur, vUv - vec2(0.0, uTexel.y)).r - 0.5;
            float t = texture2D(uCur, vUv + vec2(0.0, uTexel.y)).r - 0.5;
            float pr = texture2D(uPrev, vUv).r - 0.5;
            float nh = (l + r + b + t) * 0.5 - pr;      // the wave equation
            nh *= 0.986;                                 // damping — waves die naturally
            float ds = distance(vUv, uSplat);
            nh -= uSplatAmp * exp(-ds * ds * 1400.0);    // the cursor pushes the surface down
            if (abs(nh) < 0.0035) nh = 0.0;              // 8-bit rest deadzone (no residue)
            gl_FragColor = vec4(clamp(nh, -0.5, 0.5) + 0.5, 0.0, 0.0, 1.0);
          }`;
        const simFs = compile(gl.FRAGMENT_SHADER, simFsrc);
        let simProg: WebGLProgram | null = null;
        let sCur: WebGLUniformLocation | null = null, sPrev: WebGLUniformLocation | null = null,
            sTexel: WebGLUniformLocation | null = null, sSplat: WebGLUniformLocation | null = null,
            sAmp: WebGLUniformLocation | null = null;
        if (simFs) {
          const sp = gl.createProgram()!;
          gl.attachShader(sp, vs!); gl.attachShader(sp, simFs); gl.linkProgram(sp);
          if (gl.getProgramParameter(sp, gl.LINK_STATUS)) {
            simProg = sp;
            const sLoc = gl.getAttribLocation(sp, "p");
            gl.enableVertexAttribArray(sLoc);
            gl.vertexAttribPointer(sLoc, 2, gl.FLOAT, false, 0, 0);
            sCur = gl.getUniformLocation(sp, "uCur");
            sPrev = gl.getUniformLocation(sp, "uPrev");
            sTexel = gl.getUniformLocation(sp, "uTexel");
            sSplat = gl.getUniformLocation(sp, "uSplat");
            sAmp = gl.getUniformLocation(sp, "uSplatAmp");
          }
        }
        const r0 = wrap.getBoundingClientRect();
        const SIMW = 256;
        const SIMH = Math.max(64, Math.min(256, Math.round(SIMW * (r0.height || 1) / Math.max(r0.width, 1))));
        const mkSim = () => {
          const tex = gl.createTexture()!;
          gl.bindTexture(gl.TEXTURE_2D, tex);
          gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, SIMW, SIMH, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
          gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
          gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
          gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
          gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
          const fbo = gl.createFramebuffer()!;
          gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
          gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, tex, 0);
          gl.clearColor(0.5, 0.0, 0.0, 1.0); gl.clear(gl.COLOR_BUFFER_BIT);   // flat rest state
          gl.bindFramebuffer(gl.FRAMEBUFFER, null);
          return { tex, fbo };
        };
        let simCur = mkSim(), simPrev = mkSim(), simOut = mkSim();
        const simReset = () => {
          for (const s of [simCur, simPrev, simOut]) {
            gl.bindFramebuffer(gl.FRAMEBUFFER, s.fbo);
            gl.clearColor(0.5, 0.0, 0.0, 1.0); gl.clear(gl.COLOR_BUFFER_BIT);
          }
          gl.bindFramebuffer(gl.FRAMEBUFFER, null);
        };
        gl.useProgram(prog);                        // back to the field program
        if (uWater) gl.uniform1i(uWater, 0);        // sim height rides texture unit 0
        if (uWTexel) gl.uniform2f(uWTexel, 1 / SIMW, 1 / SIMH);

        const hex = (v: string): [number, number, number] => {
          const c = v.trim().replace("#", "");
          const n = c.length === 3 ? c.split("").map((x) => x + x).join("") : c;
          return [parseInt(n.slice(0, 2), 16) / 255, parseInt(n.slice(2, 4), 16) / 255, parseInt(n.slice(4, 6), 16) / 255];
        };
        const setColors = () => {
          const css = getComputedStyle(document.documentElement);
          gl.uniform3fv(uBg, hex(css.getPropertyValue("--color-card") || "#161412"));
          gl.uniform3fv(uLine, hex(css.getPropertyValue("--color-cobalt") || "#e8b15a"));
          gl.uniform3fv(uDeep, hex(css.getPropertyValue("--color-cobalt-deep") || "#eebb6a"));
        };
        setColors();
        addEventListener("themechange", setColors);

        const resize = () => {
          let dpr = Math.min(devicePixelRatio || 1, bleed ? 1.25 : 1.75);
          const r = wrap.getBoundingClientRect();
          // cap the total render area: a soft background field doesn't need
          // more than ~2.2MP, and on large monitors an uncapped canvas
          // (2560×1440 × dpr² ≈ 5MP+/frame) is what makes scrolling feel heavy
          const cap = bleed ? 2200000 : 1400000;
          const area = r.width * r.height * dpr * dpr;
          if (area > cap) dpr *= Math.sqrt(cap / area);
          canvas.width = Math.max(1, Math.round(r.width * dpr));
          canvas.height = Math.max(1, Math.round(r.height * dpr));
          gl.viewport(0, 0, canvas.width, canvas.height);
          gl.uniform2f(uRes, canvas.width, canvas.height);
        };
        resize();
        addEventListener("resize", resize, { passive: true });

        // target + smoothed mouse (full-bleed listens on window so the field reacts page-wide)
        let tmx = 0.5, tmy = 0.55, mx = 0.5, my = 0.55, idle = true;
        // pointer → wave-sim splats: while the pointer moves, each frame injects
        // a velocity-scaled impulse (a continuous plowed wake). A tap injects one
        // bigger drop. Idle drift never splats, so untouched water stays still.
        let lastSX = -9, lastSY = -9, pendingTap = false;
        const setTarget = (e: PointerEvent) => {
          const r = wrap.getBoundingClientRect();
          tmx = (e.clientX - r.left) / Math.max(r.width, 1);
          tmy = 1 - (e.clientY - r.top) / Math.max(r.height, 1);
          idle = false;
        };
        (bleed ? window : wrap).addEventListener("pointerdown", () => { pendingTap = true; }, { passive: true });
        // fine pointers: field follows the cursor. Touch: it follows the finger
        // while touching (pointermove fires during the drag), then resumes the
        // idle drift on lift — all passive, so scrolling is never blocked.
        (bleed ? window : wrap).addEventListener("pointermove", setTarget, { passive: true });
        if (!fine) {
          (bleed ? window : wrap).addEventListener("pointerdown", setTarget, { passive: true });
          addEventListener("pointerup", () => { idle = true; }, { passive: true });
          addEventListener("pointercancel", () => { idle = true; }, { passive: true });
        }
        if (!bleed) wrap.addEventListener("pointerleave", () => { if (!fine) return; idle = true; });

        // mode + crossfade state
        const initMode = parseInt(wrap.getAttribute("data-mode") || "0", 10) || 0;
        let modeA = initMode, modeB = initMode, mixV = 0, curMode = initMode, fading = false;
        const setMode = (t: number) => {
          if (t === curMode && !fading) return;
          modeA = (fading && mixV >= 0.5) ? modeB : modeA;  // current visible
          modeB = t; mixV = 0; fading = true; curMode = t;
        };
        addEventListener("shadermode", (e: any) => setMode((e && e.detail | 0) || 0));

        const drawFrame = (time: number) => {
          gl.uniform1f(uTime, time);
          gl.uniform2f(uMouse, mx, my);
          gl.uniform1i(uModeA, modeA);
          gl.uniform1i(uModeB, modeB);
          gl.uniform1f(uMix, mixV);
          gl.activeTexture(gl.TEXTURE0);
          gl.bindTexture(gl.TEXTURE_2D, simCur.tex);   // freshest wave state
          gl.drawArrays(gl.TRIANGLES, 0, 3);
        };

        if (reduce) {
          drawFrame(0);
          addEventListener("shadermode", (e: any) => { const t = (e && e.detail | 0) || 0; modeA = t; modeB = t; mixV = 0; curMode = t; drawFrame(0); });
        } else {
          let running = false, looping = false, t0 = 0, last = 0, waterWasOn = false;
          const loop = (now: number) => {
            if (!running) { looping = false; return; }
            if (!t0) { t0 = now; last = now; }
            const time = (now - t0) / 1000;
            const dt = Math.min((now - last) / 1000, 0.05); last = now;
            if (fading) { mixV += dt / 0.55; if (mixV >= 1) { mixV = 0; modeA = modeB; fading = false; } }
            if (idle) { tmx = 0.5 + 0.32 * Math.cos(time * 0.18); tmy = 0.5 + 0.28 * Math.sin(time * 0.23); }
            mx += (tmx - mx) * 0.06; my += (tmy - my) * 0.06;
            // ── wave-sim step (only while Water is on screen) ──
            const waterOn = modeA === 3 || modeB === 3;
            if (waterOn && simProg) {
              if (!waterWasOn) { simReset(); lastSX = tmx; lastSY = tmy; }  // enter calm, no stale waves
              let amp = 0.0;
              if (!idle) {
                const sp = Math.hypot(tmx - lastSX, tmy - lastSY);
                if (sp > 0.0004) amp = Math.min(0.05 + sp * 2.2, 0.28) * 0.5;  // velocity-scaled plow
              }
              if (pendingTap) amp = Math.max(amp, 0.30);                       // tap = one real drop
              pendingTap = false;
              lastSX = tmx; lastSY = tmy;
              gl.useProgram(simProg);
              gl.bindFramebuffer(gl.FRAMEBUFFER, simOut.fbo);
              gl.viewport(0, 0, SIMW, SIMH);
              gl.activeTexture(gl.TEXTURE0); gl.bindTexture(gl.TEXTURE_2D, simCur.tex);
              gl.activeTexture(gl.TEXTURE1); gl.bindTexture(gl.TEXTURE_2D, simPrev.tex);
              gl.uniform1i(sCur, 0); gl.uniform1i(sPrev, 1);
              gl.uniform2f(sTexel, 1 / SIMW, 1 / SIMH);
              gl.uniform2f(sSplat, amp > 0.0 ? tmx : -9, amp > 0.0 ? tmy : -9);
              gl.uniform1f(sAmp, amp);
              gl.drawArrays(gl.TRIANGLES, 0, 3);
              const spare = simPrev; simPrev = simCur; simCur = simOut; simOut = spare;  // rotate
              gl.bindFramebuffer(gl.FRAMEBUFFER, null);
              gl.viewport(0, 0, canvas.width, canvas.height);
              gl.useProgram(prog);
              gl.activeTexture(gl.TEXTURE0);
            }
            waterWasOn = waterOn;
            drawFrame(time);
            requestAnimationFrame(loop);
          };
          const start = () => { if (!looping) { looping = true; requestAnimationFrame(loop); } };
          const io = new IntersectionObserver((es) => {
            for (const e of es) { if (e.isIntersecting) { running = true; start(); } else { running = false; } }
          }, { threshold: 0.01 });
          io.observe(wrap);
        }
      }
    }
  }
</script>
