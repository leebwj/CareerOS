---
// Blueprint Field — a hand-written WebGL fragment shader (no libraries).
// THREE switchable modes — Field (topographic contours), Flow (plasma bands),
// Dots (pulsing dot-matrix) — that crossfade into each other. Reuses one program
// (uModeA/uModeB/uMix blend). Lazy, paused offscreen, DPR-capped, static frame
// under reduced-motion. variant="bleed" → full-bleed page surface (cursor reacts
// across the whole hero); variant="band" → wide short strip.
//
// Perf (tuned for weak integrated GPUs, e.g. 2020 Intel Iris Plus):
//   • steady state evaluates the field ONCE — the 2nd mode only when crossfading
//   • integrated/mobile GPUs (or ?lowgfx) → 3 fbm octaves + lower DPR cap
//   • runtime throttle steps DPR down if frames stay slow (masked-GPU safety net)
//   • WebGL context loss reveals the CSS grid fallback + rebuilds on restore
const { variant, mode = 0 } = Astro.props;
---

<div class:list={["vp", variant === "band" && "vp--band", variant === "bleed" && "vp--bleed"]} data-mode={mode} data-cursor="Poke">
  <canvas class="vp-canvas"></canvas>
  <div class="vp-hud" aria-hidden="true">
    <span class="vp-tick tl"></span><span class="vp-tick tr"></span>
    <span class="vp-tick bl"></span><span class="vp-tick br"></span>
    <span class="vp-label vp-tl">field.glsl</span>
    <span class="vp-label vp-tr"><i class="vp-dot"></i> live</span>
    <span class="vp-label vp-br">hover to disturb&nbsp;↜</span>
  </div>
</div>

<style>
  .vp {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-card);
    box-shadow: 0 1px 2px color-mix(in oklab, var(--color-cobalt-deep) 12%, transparent);
  }
  @media (min-width: 880px) { .vp { aspect-ratio: 1 / 1; } }
  /* horizon-band variant: wide + short */
  .vp--band { aspect-ratio: auto; height: clamp(120px, 17vh, 180px); }
  @media (min-width: 880px) { .vp--band { aspect-ratio: auto; height: clamp(130px, 15vh, 190px); } }
  /* full-bleed variant: fills the hero behind the content */
  .vp--bleed { position: absolute; inset: 0; width: 100%; height: 100%; aspect-ratio: auto; border: 0; border-radius: 0; box-shadow: none; background: transparent; z-index: 0; }
  .vp--bleed .vp-hud { display: none; }
  .vp--bleed::before { opacity: .22; }

  .vp-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; transition: opacity .3s ease; }
  /* CSS blueprint grid is the no-WebGL / pre-paint / context-lost fallback */
  .vp::before {
    content: "";
    position: absolute; inset: 0; z-index: 0;
    background:
      linear-gradient(var(--color-line) 1px, transparent 1px) 0 0 / 24px 24px,
      linear-gradient(90deg, var(--color-line) 1px, transparent 1px) 0 0 / 24px 24px;
    opacity: .6;
  }
  .vp-canvas { z-index: 1; }
  /* on WebGL context loss, hide the frozen canvas so the CSS grid shows through */
  .vp-lost .vp-canvas { opacity: 0; }
  .vp-hud { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
  .vp-tick { position: absolute; width: 9px; height: 9px; border: 1.5px solid var(--color-cobalt); }
  .vp-tick.tl { top: 11px; left: 11px; border-right: 0; border-bottom: 0; }
  .vp-tick.tr { top: 11px; right: 11px; border-left: 0; border-bottom: 0; }
  .vp-tick.bl { bottom: 11px; left: 11px; border-right: 0; border-top: 0; }
  .vp-tick.br { bottom: 11px; right: 11px; border-left: 0; border-top: 0; }
  .vp-label { position: absolute; font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--color-cobalt-deep); }
  .vp-tl { top: 15px; left: 28px; }
  .vp-tr { top: 15px; right: 28px; display: flex; align-items: center; gap: 5px; }
  .vp-br { bottom: 15px; right: 28px; }
  .vp-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-cobalt); display: inline-block; animation: vpblink 1.8s steps(1) infinite; }
  @keyframes vpblink { 50% { opacity: .2; } }
  @media (prefers-reduced-motion: reduce) { .vp-dot { animation: none; } }
</style>

<script>
  // Defer the WebGL setup (context + shader compile + link) off the critical
  // path: yield one idle tick (capped at 300ms) so first paint + interactivity
  // land first. The canvas fades in anyway, so the deferral is imperceptible.
  await new Promise<void>((resolve) => {
    const ric = (window as any).requestIdleCallback as ((cb: () => void, o?: { timeout: number }) => void) | undefined;
    ric ? ric(() => resolve(), { timeout: 300 }) : setTimeout(resolve, 1);
  });

  const canvas = document.querySelector(".vp-canvas") as HTMLCanvasElement | null;
  const wrap = canvas?.closest(".vp") as HTMLElement | null;
  if (canvas && wrap) {
    let gl = canvas.getContext("webgl", { antialias: true, alpha: false, premultipliedAlpha: false }) as WebGLRenderingContext | null;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches || /[?&]nogfx\b/.test(location.search);
    const fine = matchMedia("(hover: hover) and (pointer: fine)").matches;
    const bleed = wrap.classList.contains("vp--bleed");

    if (gl) {
      // ── GPU tier ─────────────────────────────────────────────────────────
      // Integrated Intel / mobile GPUs (or software renderers) get fewer fbm
      // octaves + a lower resolution cap. Renderer string is the strongest
      // signal for the 2020 Iris Plus MacBook; core/mem are coarse fallbacks
      // for when the string is masked. ?lowgfx forces it (preview + testing).
      const detectLowPower = (ctx: WebGLRenderingContext): boolean => {
        try {
          const dbg = ctx.getExtension("WEBGL_debug_renderer_info");
          const r = (dbg ? String(ctx.getParameter((dbg as any).UNMASKED_RENDERER_WEBGL)) : "").toLowerCase();
          const weakGpu = /intel|iris|hd graphics|uhd graphics|mali|adreno|powervr|swiftshader|llvmpipe|apple gpu/.test(r);
          const fewCores = (navigator.hardwareConcurrency || 8) <= 4;
          const lowMem = ((navigator as any).deviceMemory || 8) <= 4;
          return weakGpu || fewCores || lowMem;
        } catch { return false; }
      };
      const lowPower = detectLowPower(gl) || /[?&]lowgfx\b/.test(location.search);
      const OCT = lowPower ? 3 : 5; // fbm octaves — 3 halves the noise cost on weak GPUs

      const deriv = gl.getExtension("OES_standard_derivatives");
      const W = deriv ? "fwidth(v)" : "0.03";
      const GW = deriv ? "fwidth(uv.x) * 22.0" : "0.04";

      const vsrc = `
        attribute vec2 p; varying vec2 vUv;
        void main(){ vUv = p * 0.5 + 0.5; gl_Position = vec4(p, 0.0, 1.0); }`;

      const fsrc =
        (deriv ? "#extension GL_OES_standard_derivatives : enable\n" : "") +
        `precision highp float;
        #define OCT ${OCT}
        varying vec2 vUv;
        uniform vec2  uRes;
        uniform float uTime;
        uniform vec2  uMouse;   // 0..1
        uniform vec3  uBg;
        uniform vec3  uLine;
        uniform vec3  uDeep;
        uniform int   uModeA;
        uniform int   uModeB;
        uniform float uMix;

        float hash(vec2 p){ p = fract(p * vec2(123.34, 345.45)); p += dot(p, p + 34.345); return fract(p.x * p.y); }
        float noise(vec2 p){
          vec2 i = floor(p), f = fract(p);
          float a = hash(i), b = hash(i + vec2(1.0, 0.0)), c = hash(i + vec2(0.0, 1.0)), d = hash(i + vec2(1.0, 1.0));
          vec2 u = f * f * (3.0 - 2.0 * f);
          return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
        }
        float fbm(vec2 p){
          float s = 0.0, a = 0.5; mat2 m = mat2(1.6, 1.2, -1.2, 1.6);
          for(int i = 0; i < OCT; i++){ s += a * noise(p); p = m * p; a *= 0.5; }
          return s;
        }

        // mode 0 — topographic contour lines + faint CAD grid
        vec3 fxContour(vec2 p, vec2 uv, float ar, float ripple){
          float t = uTime * 0.05;
          vec2 q = vec2(fbm(p + vec2(0.0, t)), fbm(p + vec2(5.2, -t)));
          float field = fbm(p + 1.7 * q + ripple * 0.9) + ripple * 0.22;
          float v = field * 7.0;
          float w = ${W};
          float d = abs(fract(v) - 0.5);
          float line = 1.0 - smoothstep(0.0, max(w * 1.4, 0.001), d);
          vec2 g = abs(fract(uv * vec2(22.0 * ar, 22.0)) - 0.5);
          float grid = 1.0 - smoothstep(0.0, max(${GW}, 0.001), min(g.x, g.y));
          vec3 col = uBg;
          col = mix(col, uDeep, grid * 0.10);
          col = mix(col, uLine, line * 0.85);
          col = mix(col, uLine, ripple * 0.16);
          return col;
        }
        // mode 1 — flowing plasma bands (domain-warped)
        vec3 fxFlow(vec2 p, vec2 uv, float ripple){
          float t = uTime * 0.04;
          vec2 q = vec2(fbm(p * 0.8 + vec2(0.0, t)), fbm(p * 0.8 + vec2(3.1, -t)));
          float f = fbm(p * 0.9 + 2.0 * q + ripple * 1.2);
          float bands = 0.5 + 0.5 * sin(f * 9.0 + uTime * 0.25);
          float glow = smoothstep(0.32, 0.95, bands);
          vec3 col = mix(uBg, mix(uDeep, uLine, 0.65), glow * 0.5);
          col = mix(col, uLine, ripple * 0.25);
          return col;
        }
        // mode 2 — pulsing dot matrix (field drives dot radius)
        vec3 fxDots(vec2 p, vec2 uv, float ar, float ripple){
          float field = fbm(p * 0.7 + uTime * 0.05) + ripple * 0.9;
          vec2 cell = fract(uv * vec2(30.0 * ar, 30.0)) - 0.5;
          float d = length(cell);
          float r = 0.10 + 0.36 * clamp(field, 0.0, 1.2);
          float dot = 1.0 - smoothstep(r - 0.05, r, d);
          return mix(uBg, uLine, dot * 0.9);
        }
        vec3 pick(int mode, vec2 p, vec2 uv, float ar, float ripple){
          if(mode == 1) return fxFlow(p, uv, ripple);
          else if(mode == 2) return fxDots(p, uv, ar, ripple);
          return fxContour(p, uv, ar, ripple);
        }

        void main(){
          vec2 uv = vUv;
          float ar = uRes.x / max(uRes.y, 1.0);
          vec2 p = vec2(uv.x * ar, uv.y) * 3.0;
          vec2 m = vec2(uMouse.x * ar, uMouse.y) * 3.0;
          float md = distance(p, m);
          float ripple = exp(-md * md * 0.6);

          // Steady state (uMix ~ 0) evaluates the field ONCE. uMix/uModeA/uModeB
          // are uniforms, so this branch is fully coherent — every fragment takes
          // the same path, no divergence — and the 2nd mode is only paid for
          // during the brief crossfade on a mode switch. ~2x fill-rate at rest.
          vec3 col;
          if (uMix < 0.0025) {
            col = pick(uModeA, p, uv, ar, ripple);
          } else {
            vec3 cA = pick(uModeA, p, uv, ar, ripple);
            vec3 cB = pick(uModeB, p, uv, ar, ripple);
            col = mix(cA, cB, clamp(uMix, 0.0, 1.0));
          }

          float vig = smoothstep(1.25, 0.25, distance(uv, vec2(0.5)));
          col = mix(uBg, col, 0.4 + 0.6 * vig);
          gl_FragColor = vec4(col, 1.0);
        }`;

      // ── program build — re-runnable so a context-restore can rebuild it ────
      const compile = (type: number, src: string) => {
        const sh = gl!.createShader(type)!;
        gl!.shaderSource(sh, src); gl!.compileShader(sh);
        return gl!.getShaderParameter(sh, gl!.COMPILE_STATUS) ? sh : null;
      };
      let prog: WebGLProgram | null = null;
      let L: Record<string, WebGLUniformLocation | null> = {};
      const build = (): boolean => {
        const vs = compile(gl!.VERTEX_SHADER, vsrc);
        const fs = compile(gl!.FRAGMENT_SHADER, fsrc);
        if (!vs || !fs) return false;
        const pr = gl!.createProgram()!;
        gl!.attachShader(pr, vs); gl!.attachShader(pr, fs); gl!.linkProgram(pr);
        if (!gl!.getProgramParameter(pr, gl!.LINK_STATUS)) return false;
        prog = pr;
        gl!.useProgram(prog);

        const buf = gl!.createBuffer();
        gl!.bindBuffer(gl!.ARRAY_BUFFER, buf);
        gl!.bufferData(gl!.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl!.STATIC_DRAW);
        const loc = gl!.getAttribLocation(prog, "p");
        gl!.enableVertexAttribArray(loc);
        gl!.vertexAttribPointer(loc, 2, gl!.FLOAT, false, 0, 0);

        L = {};
        for (const n of ["uRes", "uTime", "uMouse", "uBg", "uLine", "uDeep", "uModeA", "uModeB", "uMix"]) {
          L[n] = gl!.getUniformLocation(prog, n);
        }
        return true;
      };

      if (build()) {
        const hex = (v: string): [number, number, number] => {
          const c = v.trim().replace("#", "");
          const n = c.length === 3 ? c.split("").map((x) => x + x).join("") : c;
          return [parseInt(n.slice(0, 2), 16) / 255, parseInt(n.slice(2, 4), 16) / 255, parseInt(n.slice(4, 6), 16) / 255];
        };
        const setColors = () => {
          const css = getComputedStyle(document.documentElement);
          gl!.uniform3fv(L.uBg, hex(css.getPropertyValue("--color-card") || "#161412"));
          gl!.uniform3fv(L.uLine, hex(css.getPropertyValue("--color-cobalt") || "#e8b15a"));
          gl!.uniform3fv(L.uDeep, hex(css.getPropertyValue("--color-cobalt-deep") || "#eebb6a"));
        };
        setColors();
        addEventListener("themechange", setColors);

        // resolution: DPR cap + a total-pixel cap. Weak GPUs start lower, and the
        // runtime throttle can push qScale down further if frames stay slow.
        let qScale = 1;
        let targetFps = lowPower ? 30 : 60;   // ambient field is fine at 30; the throttle can drop it further
        const dprCap = bleed ? (lowPower ? 0.85 : 1.25) : (lowPower ? 1.1 : 1.75);
        const areaCap = bleed ? (lowPower ? 1200000 : 2200000) : (lowPower ? 850000 : 1400000);
        const resize = () => {
          let dpr = Math.min(devicePixelRatio || 1, dprCap) * qScale;
          const r = wrap.getBoundingClientRect();
          const area = r.width * r.height * dpr * dpr;
          if (area > areaCap) dpr *= Math.sqrt(areaCap / area);
          canvas.width = Math.max(1, Math.round(r.width * dpr));
          canvas.height = Math.max(1, Math.round(r.height * dpr));
          gl!.viewport(0, 0, canvas.width, canvas.height);
          if (L.uRes) gl!.uniform2f(L.uRes, canvas.width, canvas.height);
        };
        resize();
        addEventListener("resize", resize, { passive: true });

        // target + smoothed mouse (full-bleed listens on window so the field reacts page-wide)
        let tmx = 0.5, tmy = 0.55, mx = 0.5, my = 0.55, idle = true;
        const setTarget = (e: PointerEvent) => {
          const r = wrap.getBoundingClientRect();
          tmx = (e.clientX - r.left) / Math.max(r.width, 1);
          tmy = 1 - (e.clientY - r.top) / Math.max(r.height, 1);
          idle = false;
        };
        // fine pointers: field follows the cursor. Touch: it follows the finger
        // while touching (pointermove fires during the drag), then resumes the
        // idle drift on lift — all passive, so scrolling is never blocked.
        (bleed ? window : wrap).addEventListener("pointermove", setTarget, { passive: true });
        if (!fine) {
          (bleed ? window : wrap).addEventListener("pointerdown", setTarget, { passive: true });
          addEventListener("pointerup", () => { idle = true; }, { passive: true });
          addEventListener("pointercancel", () => { idle = true; }, { passive: true });
        }
        if (!bleed) wrap.addEventListener("pointerleave", () => { if (!fine) return; idle = true; });

        // mode + crossfade state
        const initMode = parseInt(wrap.getAttribute("data-mode") || "0", 10) || 0;
        let modeA = initMode, modeB = initMode, mixV = 0, curMode = initMode, fading = false;
        const setMode = (t: number) => {
          if (t === curMode && !fading) return;
          modeA = (fading && mixV >= 0.5) ? modeB : modeA;  // current visible
          modeB = t; mixV = 0; fading = true; curMode = t;
        };
        addEventListener("shadermode", (e: any) => setMode((e && e.detail | 0) || 0));

        const drawFrame = (time: number) => {
          if (!prog) return;
          gl!.uniform1f(L.uTime, time);
          gl!.uniform2f(L.uMouse, mx, my);
          gl!.uniform1i(L.uModeA, modeA);
          gl!.uniform1i(L.uModeB, modeB);
          gl!.uniform1f(L.uMix, mixV);
          gl!.drawArrays(gl!.TRIANGLES, 0, 3);
        };

        let running = false, looping = false;
        let start = () => {};

        // ── context loss → show the CSS grid fallback; restore → rebuild ──────
        canvas.addEventListener("webglcontextlost", (e) => {
          e.preventDefault();      // signal we can recover (else no restore fires)
          running = false;
          wrap.classList.add("vp-lost");
        }, false);
        canvas.addEventListener("webglcontextrestored", () => {
          if (!build()) return;    // rebuild program/buffers/uniforms on the new context
          setColors();
          resize();
          wrap.classList.remove("vp-lost");
          if (reduce) { drawFrame(0); return; }
          running = true;
          start();
        }, false);

        if (reduce) {
          drawFrame(0);
          addEventListener("shadermode", (e: any) => { const t = (e && e.detail | 0) || 0; modeA = t; modeB = t; mixV = 0; curMode = t; drawFrame(0); });
        } else {
          // Frame pacing + self-correcting quality. A soft ambient field doesn't
          // need 60fps, so we cap it (30 on weak GPUs) and skip rAF ticks that
          // come early — that alone halves fragment work. If real inter-draw time
          // still balloons, we step DOWN decisively: fps → resolution → lower fps
          // → freeze to a static frame. This converges to smooth on ANY device,
          // even when GPU detection is masked (Safari/Chrome on Mac report a
          // generic renderer), so it no longer depends on catching "Intel/Iris".
          let t0 = 0, lastDraw = 0, slow = 0, steps = 0, frozen = false;
          const FLOOR = 0.42;
          const loop = (now: number) => {
            if (!running) { looping = false; return; }
            requestAnimationFrame(loop);
            if (!t0) { t0 = now; lastDraw = now - 999; }
            const time = (now - t0) / 1000;
            const interval = 1000 / targetFps;
            const sinceDraw = now - lastDraw;
            if (sinceDraw < interval - 2) return;            // too soon for the target fps → skip (saves GPU)

            // Inter-draw time balloons past the budget when the GPU can't keep
            // pace even under the fps cap → react within ~0.3s and step down.
            if (!frozen && steps < 6) {
              if (sinceDraw > interval + 9) slow++; else if (slow > 0) slow -= 2;
              if (slow > 10) {
                slow = 0; steps++;
                if (targetFps > 30) targetFps = 30;                              // 1) drop to 30fps
                else if (qScale > FLOOR) { qScale = Math.max(FLOOR, qScale * 0.72); resize(); }  // 2) shrink resolution
                else if (targetFps > 20) targetFps = 20;                         // 3) drop to 20fps
                else frozen = true;                                              // 4) give up → static frame
              }
            }

            const dt = Math.min(sinceDraw / 1000, 0.08);
            lastDraw = now;
            if (fading) { mixV += dt / 0.55; if (mixV >= 1) { mixV = 0; modeA = modeB; fading = false; } }
            if (idle) { tmx = 0.5 + 0.32 * Math.cos(time * 0.18); tmy = 0.5 + 0.28 * Math.sin(time * 0.23); }
            mx += (tmx - mx) * 0.06; my += (tmy - my) * 0.06;
            drawFrame(time);
            if (frozen) { running = false; looping = false; }   // last frame drawn → leave it static
          };
          start = () => { if (!looping) { looping = true; requestAnimationFrame(loop); } };
          const io = new IntersectionObserver((es) => {
            for (const e of es) { if (e.isIntersecting) { if (!frozen) { running = true; start(); } } else { running = false; } }
          }, { threshold: 0.01 });
          io.observe(wrap);
        }
      }
    }
  }
</script>
