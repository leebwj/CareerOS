---
// Compact self-contained WebGL "flow" shader for the profile card art (separate from the
// hero ShaderField so it doesn't fight over a single canvas). Cobalt-toned, IO-paused.
// The GL context + shader compile are created LAZILY on first near-view (rootMargin),
// so this 2nd context never lands on the critical path with the hero shader on load —
// a real win on weak integrated GPUs. Weak GPUs also get fewer fbm octaves.
---

<canvas class="cshader" aria-hidden="true"></canvas>

<style>
  .cshader { position: absolute; inset: 0; width: 100%; height: 100%; display: block; z-index: 0; }
</style>

<script>
  const hex = (v: string): [number, number, number] => {
    const c = v.trim().replace("#", "");
    const n = c.length === 3 ? c.split("").map((x) => x + x).join("") : c;
    return [parseInt(n.slice(0, 2), 16) / 255, parseInt(n.slice(2, 4), 16) / 255, parseInt(n.slice(4, 6), 16) / 255];
  };
  document.querySelectorAll<HTMLCanvasElement>(".cshader").forEach((canvas) => {
    const wrap = canvas.parentElement as HTMLElement;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let inited = false, running = false, looping = false;

    // All GL work is deferred into init() — called only when the card nears the
    // viewport, so the hero shader owns the GPU alone at landing.
    const init = () => {
      if (inited) return true;
      inited = true;
      const gl = canvas.getContext("webgl", { antialias: true, alpha: false }) as WebGLRenderingContext | null;
      if (!gl) return false;

      const dbg = gl.getExtension("WEBGL_debug_renderer_info");
      const rend = (dbg ? String(gl.getParameter((dbg as any).UNMASKED_RENDERER_WEBGL)) : "").toLowerCase();
      const lowPower = /intel|iris|hd graphics|uhd graphics|mali|adreno|powervr|swiftshader|llvmpipe|apple gpu/.test(rend)
        || (navigator.hardwareConcurrency || 8) <= 4 || ((navigator as any).deviceMemory || 8) <= 4
        || /[?&]lowgfx\b/.test(location.search);
      const OCT = lowPower ? 3 : 5;

      const vsrc = `attribute vec2 p; varying vec2 vUv; void main(){ vUv = p * 0.5 + 0.5; gl_Position = vec4(p, 0.0, 1.0); }`;
      const fsrc = `precision highp float; varying vec2 vUv;
        #define OCT ${OCT}
        uniform vec2 uRes; uniform float uTime; uniform vec3 uBg; uniform vec3 uLine; uniform vec3 uDeep;
        float hash(vec2 p){ p = fract(p * vec2(123.34, 345.45)); p += dot(p, p + 34.345); return fract(p.x * p.y); }
        float noise(vec2 p){ vec2 i = floor(p), f = fract(p); float a = hash(i), b = hash(i + vec2(1.,0.)), c = hash(i + vec2(0.,1.)), d = hash(i + vec2(1.,1.)); vec2 u = f * f * (3. - 2. * f); return mix(mix(a, b, u.x), mix(c, d, u.x), u.y); }
        float fbm(vec2 p){ float s = 0., a = .5; mat2 m = mat2(1.6, 1.2, -1.2, 1.6); for(int i = 0; i < OCT; i++){ s += a * noise(p); p = m * p; a *= .5; } return s; }
        void main(){
          vec2 uv = vUv; float ar = uRes.x / max(uRes.y, 1.); vec2 p = vec2(uv.x * ar, uv.y) * 3.0;
          float t = uTime * 0.05;
          vec2 q = vec2(fbm(p * 0.8 + vec2(0., t)), fbm(p * 0.8 + vec2(3.1, -t)));
          float f = fbm(p * 0.9 + 2.0 * q);
          float bands = 0.5 + 0.5 * sin(f * 9.0 + uTime * 0.3);
          float glow = smoothstep(0.3, 0.95, bands);
          vec3 col = mix(uBg, mix(uDeep, uLine, 0.6), glow * 0.7);
          float vig = smoothstep(1.3, 0.2, distance(uv, vec2(0.5)));
          col = mix(uBg, col, 0.4 + 0.6 * vig);
          gl_FragColor = vec4(col, 1.0);
        }`;
      const compile = (type: number, src: string) => { const s = gl.createShader(type)!; gl.shaderSource(s, src); gl.compileShader(s); return gl.getShaderParameter(s, gl.COMPILE_STATUS) ? s : null; };
      const vs = compile(gl.VERTEX_SHADER, vsrc), fs = compile(gl.FRAGMENT_SHADER, fsrc);
      if (!vs || !fs) return false;
      const prog = gl.createProgram()!; gl.attachShader(prog, vs); gl.attachShader(prog, fs); gl.linkProgram(prog);
      if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return false;
      gl.useProgram(prog);
      const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
      const loc = gl.getAttribLocation(prog, "p"); gl.enableVertexAttribArray(loc); gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
      const U = (n: string) => gl.getUniformLocation(prog, n);
      const uRes = U("uRes"), uTime = U("uTime"), uBg = U("uBg"), uLine = U("uLine"), uDeep = U("uDeep");
      const setColors = () => {
        const css = getComputedStyle(document.documentElement);
        // keep the art "screen" dark in both modes so it reads as a glowing inset
        gl.uniform3fv(uBg, hex("#0b0e16"));
        gl.uniform3fv(uLine, hex(css.getPropertyValue("--color-cobalt") || "#6f88cf"));
        gl.uniform3fv(uDeep, hex(css.getPropertyValue("--color-cobalt-deep") || "#9aafe2"));
      };
      setColors(); addEventListener("themechange", setColors);
      const resize = () => {
        const dpr = Math.min(devicePixelRatio || 1, lowPower ? 1.25 : 1.5);
        const r = wrap.getBoundingClientRect();
        canvas.width = Math.max(1, Math.round(r.width * dpr));
        canvas.height = Math.max(1, Math.round(r.height * dpr));
        gl.viewport(0, 0, canvas.width, canvas.height);
        gl.uniform2f(uRes, canvas.width, canvas.height);
      };
      resize(); addEventListener("resize", resize, { passive: true });
      const draw = (time: number) => { gl.uniform1f(uTime, time); gl.drawArrays(gl.TRIANGLES, 0, 3); };

      // context loss: the parent .pcard__art keeps a dark bg, so just stop cleanly
      canvas.addEventListener("webglcontextlost", (e) => { e.preventDefault(); running = false; }, false);

      if (reduce) { draw(0); return true; }
      let t0 = 0;
      const loop = (now: number) => { if (!running) { looping = false; return; } if (!t0) t0 = now; draw((now - t0) / 1000); requestAnimationFrame(loop); };
      start = () => { if (!looping) { looping = true; requestAnimationFrame(loop); } };
      return true;
    };

    let start = () => {};
    // rootMargin gives the lazy init a head start so the shader is warm just
    // before the card scrolls into view; threshold 0.01 then drives play/pause.
    const io = new IntersectionObserver((es) => {
      for (const e of es) {
        if (e.isIntersecting) { if (!init()) { io.disconnect(); return; } running = true; start(); }
        else running = false;
      }
    }, { threshold: 0.01, rootMargin: "300px 0px" });
    io.observe(wrap);
  });
</script>
