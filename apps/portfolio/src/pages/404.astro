---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShaderField from "../components/ShaderField.astro";
---

<BaseLayout title="404 · Brian Wonjun Lee">
  <main class="nf">
    <div class="nf__shader" aria-hidden="true"><ShaderField variant="bleed" mode={2} /></div>
    <span class="nf__scrim" aria-hidden="true"></span>
    <div class="wrap nf__inner">
      <p class="kicker"><span class="num">404</span>Page not found</p>
      <h1 class="nf__title">This page wandered off.</h1>
      <p class="nf__body">
        The link may be broken, or the page may have moved. Let's get you back
        to the work.
      </p>
      <div class="nf__actions">
        <a href="/" class="btn btn-primary" data-magnetic="0.3" data-cursor="Home">← Back home</a>
        <a href="/#work" class="btn btn-ghost" data-cursor="Work">See the work</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .nf { position: relative; overflow: hidden; min-height: 82vh; display: grid; place-items: center; padding: 4rem 0; }
  .nf__shader { position: absolute; inset: 0; z-index: 0; opacity: .35; }
  .nf__scrim { position: absolute; inset: 0; z-index: 0; background: radial-gradient(90% 70% at 50% 55%, color-mix(in oklab, var(--color-canvas) 55%, transparent), var(--color-canvas) 95%); }
  .nf__inner { position: relative; z-index: 1; max-width: 640px; width: 100%; }
  .nf__title { font-family: var(--font-display); font-weight: 700; font-size: clamp(2.4rem, 7vw, 4.6rem); line-height: 1.02; letter-spacing: -0.04em; margin-top: 1rem; text-wrap: balance; }
  .nf__body { margin-top: 1.2rem; max-width: 46ch; font-size: 1.1rem; line-height: 1.55; color: var(--color-muted); }
  .nf__actions { margin-top: 2.2rem; display: flex; flex-wrap: wrap; gap: .8rem; }
</style>
