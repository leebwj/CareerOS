---
import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";

// read whatever's in public/art/ at build time — add/remove images freely
const dir = path.join(process.cwd(), "public", "art");
const files = fs
  .readdirSync(dir)
  .filter((f) => /\.(jpe?g|png|webp|avif)$/i.test(f))
  .sort();
const pieces = files.map((f) => ({ src: `/art/${f}` }));
---

<BaseLayout
  title="Art — Brian Wonjun Lee"
  description="Selected art by Brian Lee — 3D renders, light installations, spatial compositions, drawings, and studies."
>
  <main class="art">
    <header class="art-top">
      <a href="/" class="art-back" data-cursor="home">← Brian Lee</a>
      <span class="art-yr">Studio · Selected Works</span>
    </header>

    <section class="art-intro reveal">
      <h1 class="art-title">Art</h1>
      <p class="art-lede">
        A quieter room — renders, light installations, spatial compositions,
        drawings, and studies made over the years.
      </p>
    </section>

    <section class="art-grid">
      {
        pieces.map((p, i) => (
          <button
            class="art-cell reveal"
            style={`--d:${(i % 6) * 40}ms`}
            data-full={p.src}
            data-cursor="view"
            data-cursor-keep
            aria-label="Open artwork"
          >
            <img src={p.src} alt="" loading="lazy" decoding="async" />
          </button>
        ))
      }
    </section>
  </main>

  <!-- lightbox -->
  <div class="lb" id="lb" aria-hidden="true">
    <button class="lb-close" id="lb-close" aria-label="Close">✕</button>
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous">‹</button>
    <img class="lb-img" id="lb-img" alt="" />
    <button class="lb-nav lb-next" id="lb-next" aria-label="Next">›</button>
    <div class="lb-count" id="lb-count"></div>
  </div>
</BaseLayout>

<style>
  /* calm palette, adapts to the site's light/dark mode */
  .art {
    --paper: #0c0c10;
    --ink: #ececf1;
    --muted: #8b8b96;
    --line: rgba(255, 255, 255, 0.1);
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    padding: 0 clamp(18px, 5vw, 64px) 80px;
  }
  :global([data-mode="light"]) .art {
    --paper: #f5f5f0;
    --ink: #1b1b20;
    --muted: #6a6a72;
    --line: rgba(0, 0, 0, 0.1);
  }

  .art-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 26px 0 22px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(1.2) blur(8px);
    z-index: 5;
  }
  .art-back { color: var(--ink); text-decoration: none; }
  .art-back:hover { color: var(--muted); }
  .art-yr { color: var(--muted); text-transform: uppercase; }

  .art-intro { padding: clamp(48px, 12vh, 130px) 0 clamp(40px, 8vh, 80px); max-width: 640px; }
  .art-title {
    font-family: "Mona Sans", sans-serif;
    font-weight: 700;
    font-size: clamp(52px, 12vw, 132px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin: 0 0 22px;
  }
  .art-lede { font-size: clamp(15px, 2vw, 18px); line-height: 1.6; color: var(--muted); max-width: 44ch; margin: 0; }

  /* masonry via CSS columns — organic, gallery-like */
  .art-grid { column-count: 3; column-gap: clamp(14px, 2vw, 26px); }
  @media (max-width: 1000px) { .art-grid { column-count: 2; } }
  @media (max-width: 560px) { .art-grid { column-count: 1; } }

  .art-cell {
    display: block;
    width: 100%;
    margin: 0 0 clamp(14px, 2vw, 26px);
    padding: 0;
    border: 0;
    background: var(--line);
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    break-inside: avoid;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 0.5s;
  }
  .art-cell img {
    display: block;
    width: 100%;
    height: auto;
    filter: saturate(0.96);
    transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.6s;
  }
  @media (hover: hover) {
    .art-cell:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(0, 0, 0, 0.28); }
    .art-cell:hover img { transform: scale(1.03); filter: saturate(1.05); }
  }

  /* reveal (BaseLayout's IntersectionObserver toggles .is-in) */
  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.7s ease var(--d, 0ms), transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) var(--d, 0ms); }
  .reveal.is-in { opacity: 1; transform: none; }

  /* lightbox */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    place-items: center;
    background: rgba(6, 6, 9, 0.94);
    backdrop-filter: blur(6px);
    padding: clamp(16px, 4vw, 60px);
  }
  .lb.open { display: grid; }
  .lb-img { max-width: 92vw; max-height: 88vh; object-fit: contain; border-radius: 4px; box-shadow: 0 20px 80px rgba(0, 0, 0, 0.5); animation: lbin 0.4s cubic-bezier(0.2, 0.7, 0.2, 1); }
  @keyframes lbin { from { opacity: 0; transform: scale(0.985); } to { opacity: 1; transform: none; } }
  .lb-close, .lb-nav {
    position: absolute;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 0.2s;
  }
  .lb-close:hover, .lb-nav:hover { background: rgba(255, 255, 255, 0.18); }
  .lb-close { top: 20px; right: 22px; width: 42px; height: 42px; font-size: 16px; }
  .lb-nav { top: 50%; transform: translateY(-50%); width: 52px; height: 52px; font-size: 30px; line-height: 0; }
  .lb-prev { left: clamp(12px, 3vw, 40px); }
  .lb-next { right: clamp(12px, 3vw, 40px); }
  .lb-count { position: absolute; bottom: 22px; left: 0; right: 0; text-align: center; color: rgba(255, 255, 255, 0.6); font-family: "Geist Mono", monospace; font-size: 12px; letter-spacing: 0.1em; }
  @media (max-width: 560px) { .lb-nav { width: 42px; height: 42px; font-size: 24px; } }
</style>

<script is:inline>
  (() => {
    const cells = [...document.querySelectorAll(".art-cell")];
    const srcs = cells.map((c) => c.getAttribute("data-full"));
    const lb = document.getElementById("lb");
    const img = document.getElementById("lb-img");
    const count = document.getElementById("lb-count");
    let i = 0;
    const show = (n) => {
      i = (n + srcs.length) % srcs.length;
      img.src = srcs[i];
      count.textContent = i + 1 + " / " + srcs.length;
    };
    const open = (n) => { show(n); lb.classList.add("open"); lb.setAttribute("aria-hidden", "false"); document.body.style.overflow = "hidden"; };
    const close = () => { lb.classList.remove("open"); lb.setAttribute("aria-hidden", "true"); document.body.style.overflow = ""; };
    cells.forEach((c, n) => c.addEventListener("click", () => open(n)));
    document.getElementById("lb-close").addEventListener("click", close);
    document.getElementById("lb-prev").addEventListener("click", (e) => { e.stopPropagation(); show(i - 1); });
    document.getElementById("lb-next").addEventListener("click", (e) => { e.stopPropagation(); show(i + 1); });
    lb.addEventListener("click", (e) => { if (e.target === lb || e.target === img) close(); });
    addEventListener("keydown", (e) => {
      if (!lb.classList.contains("open")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") show(i - 1);
      else if (e.key === "ArrowRight") show(i + 1);
    });
  })();
</script>
