---
import BaseLayout from "../layouts/BaseLayout.astro";
import projects from "../data/art.json";

// cover + count are precomputed in art.json (image, youtube thumb, or video frame)
const withCover = projects.map((p) => ({
  ...p,
  count: p.images.length + p.youtube.length + (p.video ? 1 : 0) + (p.videoPending ? 1 : 0),
}));
---

<BaseLayout
  title="Art — Brian Wonjun Lee"
  description="Selected art by Brian Lee — 3D renders, light installations, spatial compositions, drawings, and studies."
>
  <main class="art">
    <header class="art-top">
      <a href="/" class="art-back" data-cursor="home">← Brian Lee</a>
      <div class="art-top-r">
        <span class="art-yr">Studio · Selected Works</span>
        <button id="mode-toggle" class="art-mode" aria-label="Toggle light / dark" data-cursor="light / dark">
          <svg class="i-sun" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" stroke-linecap="round"/></svg>
          <svg class="i-moon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8z" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </header>

    <section class="art-intro reveal">
      <h1 class="art-title">Art</h1>
      <p class="art-lede">
        A quieter room — 3D renders, light installations, spatial compositions,
        drawings, and studies made over the years.
      </p>
    </section>

    <section class="ag-grid">
      {
        withCover.map((p, i) => (
          <button
            class="ag-card reveal"
            style={`--d:${(i % 3) * 45}ms`}
            data-i={i}
            data-cursor="open"
            data-cursor-keep
            aria-label={`Open ${p.title}`}
          >
            {p.cover ? (
              <img class="ag-img" src={p.cover} alt={p.title} loading="lazy" decoding="async" />
            ) : (
              <span class="ag-ph">▶</span>
            )}
            <span class="ag-cap"><span class="ag-cap-t">{p.title}</span></span>
          </button>
        ))
      }
    </section>
  </main>

  <!-- expanded project view -->
  <div class="pv" id="pv" aria-hidden="true">
    <button class="pv-close" id="pv-close" aria-label="Close">✕</button>
    <article class="pv-inner">
      <h2 class="pv-title" id="pv-title"></h2>
      <p class="pv-desc" id="pv-desc"></p>
      <div class="pv-media" id="pv-media"></div>
    </article>
  </div>

  <script type="application/json" id="art-data" set:html={JSON.stringify(projects)}></script>
</BaseLayout>

<style>
  .art {
    --paper: #0c0c10; --ink: #ececf1; --muted: #8b8b96; --line: rgba(255, 255, 255, 0.1);
    background: var(--paper); color: var(--ink); min-height: 100vh;
    padding: 0 clamp(18px, 5vw, 64px) 90px;
  }
  :global([data-mode="light"]) .art { --paper: #f5f5f0; --ink: #1b1b20; --muted: #6a6a72; --line: rgba(0, 0, 0, 0.1); }

  .art-top {
    display: flex; justify-content: space-between; align-items: center;
    padding: 22px 0; font-family: "Geist Mono", monospace; font-size: 12px; letter-spacing: 0.06em;
    border-bottom: 1px solid var(--line);
    position: sticky; top: 0; z-index: 6;
    background: color-mix(in srgb, var(--paper) 88%, transparent); backdrop-filter: saturate(1.2) blur(8px);
  }
  .art-back { color: var(--ink); text-decoration: none; }
  .art-back:hover { color: var(--muted); }
  .art-top-r { display: flex; align-items: center; gap: 16px; }
  .art-yr { color: var(--muted); text-transform: uppercase; }
  .art-mode { background: none; border: 1px solid var(--line); color: var(--ink); border-radius: 999px; width: 32px; height: 32px; display: grid; place-items: center; cursor: pointer; transition: border-color .2s, color .2s; }
  .art-mode:hover { color: var(--muted); }
  .art-mode .i-moon { display: none; }
  :global([data-mode="light"]) .art-mode .i-sun { display: none; }
  :global([data-mode="light"]) .art-mode .i-moon { display: block; }

  .art-intro { padding: clamp(46px, 11vh, 120px) 0 clamp(38px, 7vh, 74px); max-width: 640px; }
  .art-title { font-family: "Mona Sans", sans-serif; font-weight: 700; font-size: clamp(52px, 12vw, 132px); line-height: 0.92; letter-spacing: -0.03em; margin: 0 0 22px; }
  .art-lede { font-size: clamp(15px, 2vw, 18px); line-height: 1.6; color: var(--muted); max-width: 46ch; margin: 0; }

  /* scattered masonry of project covers — natural heights, image-first (title on hover) */
  .ag-grid { column-count: 3; column-gap: clamp(14px, 2vw, 26px); }
  @media (max-width: 1000px) { .ag-grid { column-count: 2; } }
  @media (max-width: 560px) { .ag-grid { column-count: 1; } }
  .ag-card { position: relative; display: block; width: 100%; margin: 0 0 clamp(14px, 2vw, 26px); padding: 0; border: 0; background: var(--line); border-radius: 6px; overflow: hidden; cursor: pointer; break-inside: avoid; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15); color: inherit; }
  .ag-img { display: block; width: 100%; height: auto; filter: saturate(0.97); transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.6s; }
  .ag-ph { display: grid; place-items: center; aspect-ratio: 4 / 3; font-size: 34px; color: var(--muted); }
  .ag-cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 40px 14px 13px; background: linear-gradient(to top, rgba(0, 0, 0, 0.62), transparent); opacity: 0; transition: opacity 0.4s ease; pointer-events: none; text-align: left; }
  .ag-cap-t { font-family: "Mona Sans", sans-serif; font-weight: 600; font-size: 14px; color: #fff; letter-spacing: -0.01em; }
  @media (hover: hover) { .ag-card:hover .ag-img { transform: scale(1.03); filter: saturate(1.06); } .ag-card:hover .ag-cap { opacity: 1; } }
  @media (hover: none) { .ag-cap { opacity: 1; } }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity .7s ease var(--d,0ms), transform .7s cubic-bezier(.2,.7,.2,1) var(--d,0ms); }
  .reveal.is-in { opacity: 1; transform: none; }

  /* expanded project view */
  .pv { position: fixed; inset: 0; z-index: 100; display: none; overflow-y: auto; background: #0a0a0d; color: #ececf1; }
  :global([data-mode="light"]) .pv { background: #f5f5f0; color: #1b1b20; }
  .pv.open { display: block; }
  .pv-inner { max-width: 860px; margin: 0 auto; padding: clamp(64px, 12vh, 120px) clamp(20px, 5vw, 40px) 100px; }
  .pv-title { font-family: "Mona Sans", sans-serif; font-weight: 700; font-size: clamp(30px, 5vw, 52px); letter-spacing: -0.02em; line-height: 1.02; margin: 0 0 20px; }
  .pv-desc { font-size: clamp(15px, 1.8vw, 17px); line-height: 1.7; color: color-mix(in srgb, currentColor 62%, transparent); white-space: pre-line; margin: 0 0 clamp(34px, 6vh, 56px); max-width: 62ch; }
  .pv-media { display: flex; flex-direction: column; gap: clamp(18px, 3vh, 34px); }
  .pv-media img, .pv-media .pv-embed { width: 100%; border-radius: 6px; display: block; }
  .pv-media img { height: auto; box-shadow: 0 10px 40px rgba(0,0,0,.22); }
  .pv-embed { aspect-ratio: 16 / 9; border: 0; }
  .pv-media video.pv-embed { aspect-ratio: auto; background: #000; max-height: 82vh; }
  .pv-pending { font-family: "Geist Mono", monospace; font-size: 12px; color: color-mix(in srgb, currentColor 50%, transparent); border: 1px dashed color-mix(in srgb, currentColor 25%, transparent); border-radius: 8px; padding: 26px; text-align: center; }
  .pv-close { position: fixed; top: 20px; right: 22px; z-index: 101; width: 42px; height: 42px; border-radius: 999px; background: rgba(128,128,128,.14); color: inherit; border: 1px solid color-mix(in srgb, currentColor 20%, transparent); font-size: 16px; cursor: pointer; display: grid; place-items: center; }
  .pv-close:hover { background: rgba(128,128,128,.26); }
</style>

<script is:inline>
  (() => {
    const data = JSON.parse(document.getElementById("art-data").textContent);
    const pv = document.getElementById("pv");
    const tEl = document.getElementById("pv-title");
    const dEl = document.getElementById("pv-desc");
    const mEl = document.getElementById("pv-media");
    const open = (i) => {
      const p = data[i];
      tEl.textContent = p.title;
      dEl.textContent = p.desc || "";
      dEl.style.display = p.desc ? "" : "none";
      let html = "";
      if (p.video) html += `<video class="pv-embed" controls playsinline preload="metadata"${p.cover ? ` poster="${p.cover}"` : ""}><source src="${p.video}" type="video/mp4"></video>`;
      p.youtube.forEach((id) => (html += `<iframe class="pv-embed" src="https://www.youtube.com/embed/${id}" title="${p.title}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>`));
      p.images.forEach((src) => (html += `<img src="${src}" alt="" loading="lazy">`));
      if (p.videoPending && !p.images.length && !p.youtube.length && !p.video) html += `<div class="pv-pending">▶ Video piece — embed coming soon.</div>`;
      mEl.innerHTML = html;
      pv.classList.add("open");
      pv.setAttribute("aria-hidden", "false");
      pv.scrollTop = 0;
      document.body.style.overflow = "hidden";
    };
    const close = () => { pv.classList.remove("open"); pv.setAttribute("aria-hidden", "true"); document.body.style.overflow = ""; mEl.innerHTML = ""; };
    document.querySelectorAll(".ag-card").forEach((b) => b.addEventListener("click", () => open(+b.dataset.i)));
    document.getElementById("pv-close").addEventListener("click", close);
    addEventListener("keydown", (e) => { if (e.key === "Escape" && pv.classList.contains("open")) close(); });
  })();
</script>
